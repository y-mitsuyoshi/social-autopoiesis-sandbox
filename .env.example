LLM_PROVIDER=ollama
MAX_TURNS=15

# エージェント定義 YAML パス（未設定時は config/agents.yaml を探索）
AGENTS_CONFIG=

# 動的エージェント順序選択（fixed=ラウンドロビン / dynamic=メタエージェント選択）
AGENT_ORDER_MODE=fixed

# コンテキスト履歴拡張（直前K発言をプロンプトに含める）
HISTORY_LENGTH=1

# Ollama モード選択（cloud=Ollama Cloud / local=ローカル Ollama）
OLLAMA_MODE=cloud

# Ollama Cloud (OpenAI互換・APIキー必須)
# エンドポイント・APIキー・モデル名は、契約する Ollama Cloud のダッシュボードで確認してください。
OLLAMA_CLOUD_API_KEY=your_ollama_cloud_api_key_here
OLLAMA_CLOUD_BASE_URL=https://ollama.com/v1
OLLAMA_CLOUD_MODEL=gemma4:31b

# Ollama Local (ローカル・APIキー不要)
OLLAMA_LOCAL_BASE_URL=http://localhost:11434/v1
OLLAMA_LOCAL_MODEL=gemma4:12b

# 後方互換性エイリアス
OLLAMA_API_KEY=your_ollama_cloud_api_key_here
OLLAMA_BASE_URL=https://ollama.com/v1
OLLAMA_MODEL=gemma4:31b

# Gemini
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com
GEMINI_MODEL=gemini-3.6-flash

# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# OpenCode Zen (Free)
OPENCODE_API_KEY=your_opencode_api_key_here
OPENCODE_BASE_URL=https://opencode.ai/zen/v1
OPENCODE_MODEL=deepseek-v4-flash-free

# OpenCode Go (Subscription)
OPENCODE_GO_API_KEY=your_opencode_api_key_here
OPENCODE_GO_BASE_URL=https://opencode.ai/zen/go/v1
OPENCODE_GO_MODEL=deepseek-v4-pro