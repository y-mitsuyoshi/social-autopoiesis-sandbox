  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "composite": true,
    "types": ["node"],
    "outDir": "./.tsbuild_node"
  },
  "include": ["vite.config.ts"]
}